a -= 1
assert(a == 1, "a harus 1")
a *= 2
assert(a == 2, "a harus 2")
a /= 2
assert(a == 1, "a harus 1")

fungsi tambah(a: fungsi(): angka): angka
    kembali a()+1
tutup

